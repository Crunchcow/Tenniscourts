# ==========================================
# Tennisplatz-Buchung – Konfiguration
# ==========================================

# Django
SECRET_KEY=bitte-aendern-vor-produktionseinsatz
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Datenbank (leer = SQLite für lokale Entwicklung)
# DATABASE_URL=postgresql://tennis:secret@localhost:5432/tenniscourts

# ==========================================
# Buchungsregeln
# ==========================================
# Auf true setzen, um Freigabe durch Verwaltung zu aktivieren
APPROVAL_REQUIRED=false

# ==========================================
# Admin API
# ==========================================
# Geheimen Token für Verwaltungs-Frontend setzen
ADMIN_API_TOKEN=sicheres-geheimnis-hier-eintragen
ADMIN_PASSWORD=tennis-admin-2024

# ==========================================
# E-Mail (SMTP)
# ==========================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.de
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=tennis@westfalia-osterwick.de
EMAIL_HOST_PASSWORD=email-passwort-hier

DEFAULT_FROM_EMAIL=tennis@westfalia-osterwick.de
ADMIN_EMAIL=Lemke@westfalia-osterwick.de

# ==========================================
# Frontend URL (für Stornierungslinks in E-Mails)
# ==========================================
SITE_URL=http://localhost:5173

# ==========================================
# CORS (Frontend-Origin)
# ==========================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
